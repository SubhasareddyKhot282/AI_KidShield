# ============================================================
#  SafeGuard AI — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# --- Email Alert Settings (Gmail App Password) ---
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
PARENT_EMAIL=parent@gmail.com

# --- Flask Settings ---
FLASK_SECRET_KEY=safeguard_super_secret_key_2024
FLASK_PORT=5000
FLASK_DEBUG=False

# --- ML Model Settings ---
ML_MODEL_NAME=cardiffnlp/twitter-roberta-base-offensive
ML_THRESHOLD=0.50

# --- Child Profile ---
CHILD_NAME=Aarav Sharma
CHILD_DEVICE=Laptop

# --- Screenshot & Audio ---
SCREENSHOT_DIR=screenshots
AUDIO_DIR=audio
AUDIO_DURATION_SECONDS=30

# --- Monitoring ---
KEYLOG_REPORT_INTERVAL=60
ENABLE_AUDIO_RECORD=True
ENABLE_SCREENSHOT=True
